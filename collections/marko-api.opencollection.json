{
  "opencollection": "1.0.0",
  "info": {
    "name": "Aramark Marko API",
    "version": "1.0.0"
  },
  "request": {
    "auth": {
      "type": "apikey",
      "key": "apiKey",
      "value": "{{apiKey}}",
      "placement": "header"
    }
  },
  "items": [
    {
      "info": {
        "name": "Organization",
