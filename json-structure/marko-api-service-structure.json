{
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Service identifier",
      "example": "SVC-001"
    },
    "type": {
      "type": "string",
      "description": "Service type",
      "enum": [
        "FOOD_SERVICE",
        "FACILITIES",
        "UNIFORM",
        "RETAIL"
      ],
      "example": "FOOD_SERVICE"
    },
    "locationId": {
      "type": "string",
      "description": "Location identifier",
      "example": "LOC-001"
    },
    "status": {
      "type": "string",
      "description": "Service status",
      "enum": [
        "ACTIVE",
        "INACTIVE",
        "SUSPENDED"
      ],
      "example": "ACTIVE"
    },
    "name": {
      "type": "string",
      "description": "Service name",
      "example": "Campus Dining"
    }
  },
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/aramark/refs/heads/main/json-structure/marko-api-service-structure.json",
  "name": "Service",
  "description": "Service schema from Aramark Marko API"
}